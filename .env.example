# ════════════════════════════════════════════════════════════
# Multimodal Agentic RAG — Environment Configuration
# Copy to .env and fill values for local development.
# On Render, set these via the Dashboard (Environment tab).
# ════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────
APP_NAME=MultimodalAgenticRAG
APP_ENV=development
DEBUG=true
SECRET_KEY=CHANGE_ME_RANDOM_32_CHARS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── MongoDB ────────────────────────────────────────────────
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=agentic_rag

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# ── Qdrant ─────────────────────────────────────────────────
# Local:        http://localhost:6333
# Qdrant Cloud: https://xxxx.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents
QDRANT_API_KEY=                   # leave blank for local

# ── LLM API Keys ───────────────────────────────────────────
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY
OPENAI_API_KEY=YOUR_OPENAI_KEY
TAVILY_API_KEY=YOUR_TAVILY_KEY
COHERE_API_KEY=YOUR_COHERE_KEY

# ── JWT Auth ───────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Embeddings ─────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── File Uploads ───────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# ── Frontend (Vite) ────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws
VITE_APP_NAME=AgenticRAG
